{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (exe)",
      "description": "Builds the decompress executable",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "DECOMPRESS_BUILD_EXE": "ON",
        "DECOMPRESS_BUILD_LIB": "OFF"
      }
    },
    {
      "name": "lib",
      "displayName": "Library",
      "description": "Builds reusable static library target decompress_parser",
      "binaryDir": "${sourceDir}/build-lib",
      "cacheVariables": {
        "DECOMPRESS_BUILD_EXE": "OFF",
        "DECOMPRESS_BUILD_LIB": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "lib",
      "configurePreset": "lib"
    }
  ]
}
